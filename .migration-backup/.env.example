# =====================================
# Hospital Management System - Environment Variables
# =====================================
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to version control

# =====================================
# BACKEND (Django)
# =====================================

# Security - MUST CHANGE IN PRODUCTION
SECRET_KEY=your-super-secret-key-here-generate-one-in-production

# Debug mode - set to False in production
DEBUG=False

# Allowed hosts for Django
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.vercel.app

# =====================================
# DATABASE (PostgreSQL)
# =====================================
# For local development: postgresql://user:password@localhost:5432/hospital_db
# For Render: set DATABASE_URL in Render environment variables
# For Docker: use db:5432 as host
DATABASE_URL=postgresql://hospital_user:hospital_password@localhost:5432/hospital_db

# =====================================
# CORS & SECURITY
# =====================================
# Frontend origins that can access the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5000,https://yourfrontend.vercel.app

# Regex patterns for CORS (production deployments)
CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$,^https://.*\.onrender\.com$

# Trusted origins for CSRF protection
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://*.vercel.app,https://*.onrender.com

# =====================================
# STATIC & MEDIA FILES
# =====================================
STATIC_URL=/static/
MEDIA_URL=/media/
STATIC_ROOT=staticfiles/
MEDIA_ROOT=media/

# =====================================
# FRONTEND
# =====================================
# API endpoint for frontend
VITE_API_URL=http://localhost:8000/api

# =====================================
# DEPLOYMENT PLATFORM
# =====================================
# For Render.com:
PYTHON_VERSION=3.12.7

# =====================================
# OPTIONAL FEATURES
# =====================================
# Google OAuth (if implementing)
# GOOGLE_OAUTH_CLIENT_ID=your-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-secret

# AWS S3 (if implementing file storage)
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket

# =====================================
# LOGGING & MONITORING (Optional)
# =====================================
# LOG_LEVEL=INFO
# SENTRY_DSN=https://your-sentry-dsn

# =====================================
# NOTE: For Render deployment
# =====================================
# Set DATABASE_URL in your Render service environment variables
# Set SECRET_KEY in your Render service environment variables
# All other sensitive data should be in Render environment variables, NOT in code
